{#
  Brutalist endpoint beacon: 3 nested squares with pulse class on the outer.
  Context: {x, y, s1..s3, h1..h3}.
#}
<g data-hw-zone="endpoint" shape-rendering="crispEdges">
  <rect class="hw-chart-endpoint" x="{{ m.x1 }}" y="{{ m.y1 }}"
        width="{{ m.s1 }}" height="{{ m.s1 }}" fill="var(--dna-signal)"/>
  <rect x="{{ m.x2 }}" y="{{ m.y2 }}" width="{{ m.s2 }}" height="{{ m.s2 }}"
        fill="var(--dna-surface)"/>
  <rect x="{{ m.x3 }}" y="{{ m.y3 }}" width="{{ m.s3 }}" height="{{ m.s3 }}"
        fill="var(--dna-ink-primary)"/>
</g>
