{# Chart paradigm: brutalist DARK substrate (v0.3.2 split).
   Ported element-by-element from tier2/genomes/brutalist/emerald/brutalist-star-history-v4b.svg.
   900x500, flat slab, grain, heavy structural rules, polyline with area fill,
   crosshair markers, nested-square milestones.
   Chart fragments (area, polyline, markers, milestones) come from chart_engine. #}

{% set cw = width | default(900) %}
{% set ch = height | default(500) %}
{# v0.3.2 viewport defaults: aligned with the v0.3.2 brutalist dark chart prototype
   celadon panel. Prototype chart area spans x=90 to x=857, y=140 to y=388 —
   pre-v0.3.2 defaults (80,150,760,245) drifted axis rails 10px left and grid
   baseline 5px high relative to the locked spec. #}
{% set vx = chart_viewport_x | default(90) %}
{% set vy = chart_viewport_y | default(140) %}
{% set vw = chart_viewport_w | default(767) %}
{% set vh = chart_viewport_h | default(248) %}

<g clip-path="url(#{{ uid }}-clip)" class="{{ uid }}-chart">

  {# L0: FLAT SLAB #}
  <rect width="{{ cw }}" height="{{ ch }}" fill="var(--dna-surface)"/>

  {# L1: GRAIN — paints before the perimeter and left rail so the structural
     stroke + accent bar read as crisp ink layered over the substrate texture. #}
  <rect x="3" y="3" width="{{ cw - 6 }}" height="{{ ch - 6 }}" filter="url(#{{ uid }}-grain)"/>

  {# L2: ASYMMETRIC L-FRAME — heavy left accent rail anchors the chart as a
     Y-axis spine while the outer perimeter ships as a barely-visible 1.5px
     hairline on all four sides. The visual asymmetry (6px solid accent left,
     1.5px @ 0.25 opacity top/right/bottom) reads as an L-frame even though
     structurally the perimeter is uniform — the rail dominates the eye.
     Matches the v0.3.2 brutalist dark prototype's celadon panel exactly
     (lines 55-56 of hw-elegant-mono-star-charts-v3.html). #}
  <rect width="6" height="{{ ch }}" fill="var(--dna-signal)" data-hw-zone="accent-rail"/>
  <rect x="0.75" y="0.75" width="{{ cw - 1.5 }}" height="{{ ch - 1.5 }}" fill="none"
        stroke="var(--dna-border, var(--dna-signal))" stroke-width="1.5" stroke-opacity="0.25"/>

  {# STRUCTURAL RULES — y-coordinates from the v0.3.2 brutalist dark chart prototype
     pigment panel lines 71-78. Top rule y=42 separates identity header from
     title zone; mid rule y=122 separates title zone from chart viewport; footer
     rule y=440 separates chart from footer zone. Pre-fix the mid rule was at
     y=140 (same as viewport_y), causing the topmost Y-axis label to render
     visually on top of the rule — visible as "3K" bleeding into the title box.
     Moving the rule to y=122 puts an 18px gap between rule and chart top,
     matching the light variant's title-zone-end hairline at y=122. #}
  <line x1="3" y1="42" x2="{{ cw - 3 }}" y2="42"
        stroke="var(--dna-border, var(--dna-signal))" stroke-width="2.5" opacity="0.55"/>
  <line x1="3" y1="122" x2="{{ cw - 3 }}" y2="122"
        stroke="var(--dna-border, var(--dna-signal))" stroke-width="2.5" opacity="0.55"/>
  <line x1="3" y1="440" x2="{{ cw - 3 }}" y2="440"
        stroke="var(--dna-border, var(--dna-signal))" stroke-width="2.5" opacity="0.55"/>

  {# Y-axis rail + baseline #}
  <line x1="{{ vx }}" y1="{{ vy }}" x2="{{ vx }}" y2="{{ vy + vh }}"
        stroke="var(--dna-border, var(--dna-signal))" stroke-width="2" opacity="0.5"/>
  <line x1="{{ vx }}" y1="{{ vy + vh }}" x2="{{ vx + vw }}" y2="{{ vy + vh }}"
        stroke="var(--dna-border, var(--dna-signal))" stroke-width="2" opacity="0.5"/>

  {# Grid coordinates #}
  <text class="{{ uid }}-grid-coord" x="{{ vx + 4 }}" y="{{ vy + 10 }}">001</text>
  <text class="{{ uid }}-grid-coord" x="{{ vx + vw - 4 }}" y="{{ vy + 10 }}" text-anchor="end">002</text>
  <text class="{{ uid }}-grid-coord" x="{{ vx + 4 }}" y="{{ vy + vh - 3 }}">003</text>
  <text class="{{ uid }}-grid-coord" x="{{ vx + vw - 4 }}" y="{{ vy + vh - 3 }}" text-anchor="end">004</text>

  {# ZONE 1: HEADER #}
  <g data-hw-zone="header">
    {# Header glyph translate(20,13) unified across dark/light to match
       the v0.3.2 brutalist light chart prototype:64. 16×16 glyph at
       x=20 with text at x=42 leaves a 6px breathing gap (dark template was
       at translate(18,16) with text x=42 → 8px gap; unified to translate(20,13)
       for cross-substrate spatial parity per user feedback). #}
    <g transform="translate(20, 13)">
      <svg viewBox="0 0 24 24" width="16" height="16">
        <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" fill="var(--dna-chart-glyph, var(--dna-glyph-inner, var(--dna-signal)))"/>
      </svg>
    </g>
    {# Header user text formatted as "ELI64S / README-AI" matching prototype
       line 427 (the v0.3.2 brutalist dark chart prototype pigment panel). The
       redundant top-right repo URL was removed per visual review — the
       same URL renders in the bottom-left footer at (24, 472), so emitting
       it twice was visual clutter and pushed the status dot into an
       awkward position above the corner. #}
    {# Title formatted "OWNER / REPO" with spaces around slash, matching
       prototype line 427's "ELI64S / README-AI" cadence. chart_title is
       upper-cased repo slug "OWNER/REPO" from resolver; we re-split to
       insert visual breathing room around the separator. #}
    <text class="{{ uid }}-hdr-user" x="42" y="28">{{ chart_title | replace('/', ' / ') }}</text>
    {# Status dot y=17 centers at y=21, aligned with header text cap-center
       (text y=28 baseline minus 0.7*12/2 ≈ y=24). Pre-fix y=11 placed dot
       9px above text visual center. #}
    <rect class="{{ uid }}-status-dot" x="{{ cw - 28 }}" y="17" width="8" height="8" fill="var(--dna-signal)" shape-rendering="crispEdges"/>
  </g>

  {# ZONE 2: TITLE + HERO. Positions ported from
     the v0.3.2 brutalist dark chart prototype pigment panel lines 433-436:
       title-main at (24, 90), title-sub at (24, 108)
       hero-value at (cw-24, 90) right-anchored, hero-label at (cw-24, 108)
     Title subtitle text includes "LIFETIME GROWTH · {date range}" — date
     range derived from chart_window_label when populated. #}
  <g data-hw-zone="title">
    <text class="{{ uid }}-title-main" x="24" y="90">STAR HISTORY</text>
    {# chart_date_range from resolver: "Jan 2024 — May 2026" with em-dash.
       Prototype line 36 shows "→" right-arrow. Replace em-dash with arrow
       for the v0.3.2 brutalist cadence. #}
    <text class="{{ uid }}-title-sub" x="24" y="108">LIFETIME GROWTH{% if chart_date_range %} · {{ chart_date_range | upper | replace('—', '→') }}{% endif %}</text>

    <text class="{{ uid }}-hero-value" x="{{ cw - 24 }}" y="90" text-anchor="end">{{ chart_current_stars }}</text>
    <text class="{{ uid }}-hero-label" x="{{ cw - 24 }}" y="108" text-anchor="end">TOTAL STARS</text>
  </g>

  {# ZONE 3: CHART #}
  <g data-hw-zone="chart">
    {% for label in chart_y_labels %}
    <text class="{{ uid }}-axis-y" x="{{ vx - 8 }}" y="{{ label.y + 4 }}" text-anchor="end">{{ label.text }}</text>
    {% endfor %}

    {%- for gl in chart_gridlines %}
      {%- include "components/chart-gridlines.svg.j2" %}
    {%- endfor %}
    {%- if chart_area %}
      {%- include "components/chart-area.svg.j2" %}
    {%- endif %}
    {%- if chart_polyline %}
    <g class="{{ uid }}-ghost-line" opacity="0.15">{% include "components/chart-polyline.svg.j2" %}</g>
    {% include "components/chart-polyline.svg.j2" %}
    <g class="{{ uid }}-bright-core">{% include "components/chart-polyline.svg.j2" %}</g>
    {%- endif %}
    <g data-hw-zone="markers">
    {%- for m in chart_markers %}
      {%- set partial = 'endpoint-' ~ m.shape if m.is_endpoint else m.shape %}
      {%- include "components/chart-markers/" ~ partial ~ ".svg.j2" %}
    {%- endfor %}
    </g>
    <g data-hw-zone="milestones">
    {%- for ms in chart_milestones %}
      {%- include "components/chart-milestone-brutalist.svg.j2" %}
    {%- endfor %}
    </g>
    {%- for ax in chart_axes %}
      {%- include "components/chart-axes.svg.j2" %}
    {%- endfor %}
    {%- if chart_empty_state %}
      {%- include "components/chart-empty-state.svg.j2" %}
    {%- endif %}
  </g>

  {# X-AXIS LABELS #}
  <g data-hw-zone="x-axis">
    {% for label in chart_x_labels %}
    <text class="{{ uid }}-axis-x" x="{{ label.x }}" y="420" text-anchor="{{ label.anchor | default('middle') }}">{{ label.text }}</text>
    {% endfor %}
  </g>

  {# FOOTER #}
  <g data-hw-zone="footer">
    {# Footer is text-only per the v0.3.2 brutalist dark chart prototype.
       Prior status-marker rects were hallucinated and removed per user feedback. #}
    {# Footer text baseline y=472: footer zone spans y=440 (structural rule)
       to y=500 (canvas bottom), height 60px, center y=470. For 8px font with
       baseline-to-visual-center offset ~2.8px, baseline at y=472 puts visual
       center at y=469.2 — vertically centered in the footer zone. Pre-fix
       was at y=462, 10px above zone center. #}
    <text class="{{ uid }}-foot" x="20" y="472">github.com/{{ chart_repo }}</text>
    <text class="{{ uid }}-foot-brand" x="{{ cw - 22 }}" y="472" text-anchor="end">HYPERWEAVE · STAR HISTORY</text>
  </g>

</g>
