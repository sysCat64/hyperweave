{# Chrome horizontal-marquee BACKGROUND layers — sit BELOW the scroll-track text.
   Specimen: chrome-marquees-v2 + production marquee-horizontal.svg.
   Layer order:
     1. envelope-fill rect with bevel filter (rx=4, full mw x mh)
     2. well rect (rx=2.6, inset 4px, dark interior)
   The PERIMETER layers (inner hairline, env-rail, top accent, rim sweep)
   live in chrome-overlay.j2 so they render ABOVE the scroll text — text
   then visually scrolls UNDER them at the edges instead of over them.
#}
<g filter="url(#{{ uid }}-bevel)">
  <rect width="{{ mw }}" height="{{ mh }}" rx="{{ marquee_geom.chrome_outer_rx }}" fill="url(#{{ uid }}-envelope)"/>
</g>
<rect x="{{ marquee_geom.chrome_well_x }}" y="{{ marquee_geom.chrome_well_y }}" width="{{ chrome_well_w }}" height="{{ chrome_well_h }}" rx="{{ marquee_geom.chrome_well_rx }}" fill="url(#{{ uid }}-well)"/>
