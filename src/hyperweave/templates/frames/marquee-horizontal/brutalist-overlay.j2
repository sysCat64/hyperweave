{# Brutalist horizontal-marquee OVERLAY layers — sit ABOVE the scroll-track text.
   Renders the perimeter stroke + 4px left accent bar so they occlude scrolling
   text at the frame edges (text appears to slide UNDER the perimeter and
   accent bar instead of over them). Specimen: brutalist-marquee-v1.svg.
   Layer order (rendered on top of text):
     1. 1px perimeter stroke (genome.signal_hex @ opacity 0.4)
     2. 4px left accent bar (genome.signal_hex solid)
   Brutalism's K-override: flat slab, sharp corners (rx=0), one accent bar.
#}
<rect x="{{ marquee_geom.brutalist_border_x }}" y="{{ marquee_geom.brutalist_border_y }}" width="{{ marquee_perimeter_w }}" height="{{ marquee_perimeter_h }}"
      fill="none" stroke="{{ signal_hex }}" stroke-width="1" opacity="0.4"/>
<rect x="{{ marquee_geom.brutalist_accent_x }}" y="{{ marquee_geom.brutalist_accent_y }}" width="{{ marquee_geom.brutalist_accent_w }}" height="{{ mh }}" fill="{{ signal_hex }}"/>
