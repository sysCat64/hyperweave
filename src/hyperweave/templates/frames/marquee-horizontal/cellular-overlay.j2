{# Cellular marquee-horizontal OVERLAY — top + bottom mid_accent hairlines.

   v0.3.0 visual refresh: replaces the prior bifamily seam_mid split (top =
   primary.seam_mid, bottom = secondary.seam_mid) with a single mid_accent
   tone for both edges. The marquee is 32px tall and hairlines render at
   0.5px stroke at 0.2 opacity — a chromatic split between top and bottom
   would not perceptually communicate a paired-variant signature at this
   scale. Paired variants express their dual-tone identity through richer
   surfaces (stat card heatmap, chart cells, icon grid), so the marquee
   adopts the primary tone's mid_accent and lets bandwidth go where it
   actually carries.

   Renders ABOVE the scroll-track text so text visually slides UNDER the
   hairlines at the top/bottom edges (instead of overlapping them).
#}
{% set hairline = primary_mid_accent | default(cellular_palette.primary.mid_accent) %}

{# Top hairline #}
<rect x="{{ marquee_geom.cellular_hairline_x }}" y="{{ marquee_geom.cellular_top_hairline_y }}" width="{{ mw }}" height="{{ marquee_geom.cellular_hairline_h }}" fill="{{ hairline }}" opacity="0.2"/>

{# Bottom hairline #}
<rect x="{{ marquee_geom.cellular_hairline_x }}" y="{{ cellular_bottom_hairline_y }}" width="{{ mw }}" height="{{ marquee_geom.cellular_hairline_h }}" fill="{{ hairline }}" opacity="0.2"/>

{# v0.3.12 — DECORATIVE travelling-wave baseline rail (automata signature).
   Cells on a 6px pitch across the full width, each phase-delayed by its x so a
   bright band propagates left→right. Genome's mid_accent tone; the cells encode
   nothing — the scrolling tokens carry the data. Own @keyframes (.hw-mq-wv in
   cellular-defs.j2), not the state cascade. Positions + per-cell delays are
   resolver-supplied (liveness_rail) — zero arithmetic / literals here. #}
<g data-hw-zone="rail" shape-rendering="crispEdges">
{% for c in liveness_rail %}<rect class="hw-mq-wv" x="{{ c.x }}" y="{{ liveness_rail_y }}" width="{{ liveness_rail_w }}" height="{{ liveness_rail_h }}" fill="{{ hairline }}" style="animation-delay:{{ c.delay }}s"/>{% endfor %}
</g>
