{# Brutalist icon content: two variants keyed on icon_variant.
   brutalist-circular: single-ring, glyph-dominant, no label.
   brutalist-square: top accent bar, heavy border, glyph-dominant, no label.
   Variant keyed on icon_variant, not profile identity. #}

{% if icon_variant == 'brutalist-circular' %}
{# ================================================================
   BRUTALIST CIRCULAR -- single ring, glyph-dominant, no label
   Specimen: brutalist-icon-frames/brutalist-circular-v2.svg
   ================================================================ #}
<circle cx="{{ icon_geometry.brutalist_circle_cx }}" cy="{{ icon_geometry.brutalist_circle_cy }}" r="{{ icon_geometry.brutalist_circle_r }}" fill="var(--dna-surface)"/>
<circle cx="{{ icon_geometry.brutalist_circle_cx }}" cy="{{ icon_geometry.brutalist_circle_cy }}" r="{{ icon_geometry.brutalist_circle_r }}" fill="none" stroke="var(--dna-signal)" stroke-width="2.5"/>
{% if glyph_path %}
<svg x="{{ icon_geometry.brutalist_circle_glyph_x }}" y="{{ icon_geometry.brutalist_circle_glyph_y }}" width="{{ icon_geometry.brutalist_circle_glyph_size }}" height="{{ icon_geometry.brutalist_circle_glyph_size }}" viewBox="{{ glyph_viewbox }}">
  <path d="{{ glyph_path }}" fill="var(--dna-signal-dim)" stroke="none"/>
</svg>
{% endif %}

{% elif icon_variant == 'brutalist-square' %}
{# ================================================================
   BRUTALIST SQUARE -- accent bar, heavy border, no label
   Specimen: brutalist-icon-frames/brutalist-square-v2.svg
   ================================================================ #}
<rect x="{{ icon_geometry.brutalist_square_x }}" y="{{ icon_geometry.brutalist_square_y }}" width="{{ icon_geometry.brutalist_square_w }}" height="{{ icon_geometry.brutalist_square_h }}" fill="var(--dna-surface)"/>
<rect x="{{ icon_geometry.brutalist_square_border_x }}" y="{{ icon_geometry.brutalist_square_border_y }}" width="{{ icon_geometry.brutalist_square_border_w }}" height="{{ icon_geometry.brutalist_square_border_h }}" fill="none" stroke="var(--dna-signal)" stroke-width="2.5"/>
<rect x="{{ icon_geometry.brutalist_square_x }}" y="{{ icon_geometry.brutalist_square_y }}" width="{{ icon_geometry.brutalist_square_w }}" height="{{ icon_geometry.brutalist_square_accent_h }}" fill="var(--dna-signal)"/>
{% if glyph_path %}
<svg x="{{ icon_geometry.brutalist_square_glyph_x }}" y="{{ icon_geometry.brutalist_square_glyph_y }}" width="{{ icon_geometry.brutalist_square_glyph_size }}" height="{{ icon_geometry.brutalist_square_glyph_size }}" viewBox="{{ glyph_viewbox }}">
  <path d="{{ glyph_path }}" fill="var(--dna-signal-dim)" stroke="none"/>
</svg>
{% endif %}

{% endif %}
