{# HyperWeave Catalog Frame — editorial layout for genome/asset showcases.
   Variable height (800 wide). Multi-column grid with header, item cards,
   and footer summary. Used for documentation and presentation artifacts.
   Extends document.svg.j2.  Context: ComposeSpec dict. #}
{% extends "document.svg.j2" %}

{% block defs %}
  <linearGradient id="{{ uid }}-bg" x1="0" y1="0" x2="0" y2="1">
    <stop offset="0%" stop-color="var(--dna-surface)"/>
    <stop offset="100%" stop-color="var(--dna-surface-deep)"/>
  </linearGradient>
  {# Card hover shadow #}
  <filter id="{{ uid }}-card-shadow">
    <feDropShadow dx="0" dy="2" stdDeviation="4"
                  flood-color="var(--dna-shadow-color, black)"
                  flood-opacity="var(--dna-shadow-opacity, 0.12)"/>
  </filter>
{% endblock %}

{% block content %}
{# === Background === #}
<rect width="{{ catalog_w }}" height="{{ catalog_h }}" rx="{{ catalog_geom.frame_rx }}" fill="url(#{{ uid }}-bg)"/>
<rect x="{{ catalog_geom.border_x }}" y="{{ catalog_geom.border_y }}" width="{{ catalog_inner_w }}" height="{{ catalog_inner_h }}"
      rx="{{ catalog_geom.frame_rx }}" fill="none" stroke="var(--dna-border)" stroke-width="1"/>

{# === Header === #}
<g transform="translate({{ catalog_margin }}, {{ catalog_margin }})" data-hw-zone="catalog-header">
  <text class="m ghost" font-size="9" font-weight="600"
        letter-spacing="1.5px">{{ catalog_category | default('CATALOG') | upper }}</text>
  <text class="s ink1" font-size="28" font-weight="800" y="{{ catalog_geom.title_y }}"
        letter-spacing="-0.5px">{{ catalog_title }}</text>
{% if catalog_subtitle %}
  <text class="m ink3" font-size="11" y="{{ catalog_geom.subtitle_y }}">{{ catalog_subtitle }}</text>
{% endif %}
</g>

{# Divider #}
<line x1="{{ catalog_margin }}" y1="{{ catalog_header_end_y }}" x2="{{ catalog_right_x }}" y2="{{ catalog_header_end_y }}"
      stroke="var(--dna-border)" stroke-width="1"/>

{# === Item cards (grid layout) === #}
{% for item in catalog_cards | default([]) %}
<g transform="translate({{ item.card_x }}, {{ item.card_y }})" data-hw-zone="card-{{ loop.index0 }}"
   filter="url(#{{ uid }}-card-shadow)">
  {# Card background #}
  <rect width="{{ catalog_col_w }}" height="{{ catalog_card_h }}" rx="{{ catalog_geom.card_rx }}"
        fill="var(--dna-surface-alt)"/>
  <rect x="{{ catalog_geom.card_border_x }}" y="{{ catalog_geom.card_border_y }}" width="{{ item.card_inner_w }}" height="{{ item.card_inner_h }}"
        rx="{{ catalog_geom.card_rx }}" fill="none" stroke="var(--dna-border)" stroke-width="0.5"/>
  {# Signal accent top bar #}
  <rect width="{{ catalog_col_w }}" height="{{ catalog_geom.card_accent_h }}" rx="{{ catalog_geom.card_rx }}" fill="var(--dna-signal)" opacity="0.4"/>
  {# Card content #}
  <text class="m" font-size="9" font-weight="700" fill="var(--dna-signal)"
        x="{{ catalog_geom.item_text_x }}" y="{{ catalog_geom.item_label_y }}">{{ item.label | default('') | upper }}</text>
  <text class="s ink1" font-size="13" font-weight="600"
        x="{{ catalog_geom.item_text_x }}" y="{{ catalog_geom.item_title_y }}">{{ item.title }}</text>
{% if item.description | default('') %}
  <text class="m ink3" font-size="9" x="{{ catalog_geom.item_text_x }}" y="{{ catalog_geom.item_description_y }}">{{ item.description }}</text>
{% endif %}
{% if item.meta | default('') %}
  <text class="m ghost" font-size="8" x="{{ catalog_geom.item_text_x }}" y="{{ item.meta_y }}">{{ item.meta }}</text>
{% endif %}
{% if item.badge_svg | default('') %}
  <g transform="translate({{ item.badge_x }}, {{ catalog_geom.badge_y }})">
    {{ item.badge_svg | safe }}
  </g>
{% endif %}
</g>
{% endfor %}

{# === Footer summary === #}
<text class="m ghost" font-size="9" x="{{ catalog_margin }}" y="{{ catalog_footer_y }}">{{ catalog_footer_left }}</text>
<text class="m ghost" font-size="9" x="{{ catalog_right_x }}" y="{{ catalog_footer_y }}"
      text-anchor="end">{{ catalog_footer_right }}</text>
{% endblock %}
