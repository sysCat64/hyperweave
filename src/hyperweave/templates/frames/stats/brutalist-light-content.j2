{# Brutalist stats card — LIGHT scholar substrate. Ported element-by-element
   from the v0.3.2 brutalist light scholar full-set prototype
   (pulse stat card, lines 52-126). Light scholars invert polarity: paper
   substrate + dark gradient header panel + gold seam rebar dividers +
   dark ink activity bars.

   Same 495×280 canvas, same zone y-coordinates as dark, but DIFFERENT
   structural rule colors (gold/seam_color vs accent), DIFFERENT activity
   bar fill (ink-primary vs accent), and ADDITIONAL elements (gold border
   strips top/bottom, gold corner ornament). #}

<g clip-path="url(#{{ uid }}-clip)">
  {# (1) Paper substrate — variant surface_0 (paper). #}
  <rect width="{{ stats_layout.width }}" height="{{ stats_layout.height }}" fill="var(--dna-surface)"/>

  {# (2) Paper texture overlay — grain filter at low opacity with multiply
     blend so the texture darkens paper without affecting overlaid panels. #}
  <rect width="{{ stats_layout.width }}" height="{{ stats_layout.height }}" filter="url(#{{ uid }}-grain)" opacity="0.15" style="mix-blend-mode:multiply"/>

  {# (3) Left accent rail — 6px INK bar (brutalist scholar manuscript convention; the
     left rule is dark ink, not accent, because the accent role is reserved
     for the gold seam rebar dividers). #}
  <rect x="{{ stats_layout.rects.left_rail.x }}" y="{{ stats_layout.rects.left_rail.y }}"
        width="{{ stats_layout.rects.left_rail.w }}" height="{{ stats_layout.rects.left_rail.h }}"
        fill="var(--dna-ink-primary)"/>

  {# (4) Perimeter — 1px crimson/ink panel-top color at 0.2 opacity, inset
     0.5px (NOT 0.75px like dark — light perimeter is thinner). #}
  <rect x="{{ stats_layout.light_perimeter.x }}" y="{{ stats_layout.light_perimeter.y }}"
        width="{{ stats_layout.light_perimeter.w }}" height="{{ stats_layout.light_perimeter.h }}"
        fill="none" stroke="var(--dna-bg)" stroke-width="1" opacity="0.2"/>

  {# (5) Top + bottom gold border strips — 2px gold (seam_color) at 0.35
     opacity. Defines the brutalist scholar "manuscript margins" frame. #}
  <rect x="{{ stats_layout.rects.light_top_strip.x }}" y="{{ stats_layout.rects.light_top_strip.y }}"
        width="{{ stats_layout.rects.light_top_strip.w }}" height="{{ stats_layout.rects.light_top_strip.h }}"
        fill="var(--dna-seam-color)" opacity="0.35"/>
  <rect x="{{ stats_layout.rects.light_bottom_strip.x }}" y="{{ stats_layout.rects.light_bottom_strip.y }}"
        width="{{ stats_layout.rects.light_bottom_strip.w }}" height="{{ stats_layout.rects.light_bottom_strip.h }}"
        fill="var(--dna-seam-color)" opacity="0.35"/>

  {# (6) Header dark panel — y=2→32, fills variant panel gradient
     (crimson/sepia/cobalt/etc.). The 30px height + 2px gold seam below
     occupies the header zone exactly. #}
  <rect x="{{ stats_layout.rects.light_header_panel.x }}" y="{{ stats_layout.rects.light_header_panel.y }}"
        width="{{ stats_layout.rects.light_header_panel.w }}" height="{{ stats_layout.rects.light_header_panel.h }}"
        fill="url(#{{ uid }}-panel)"/>
  <rect x="{{ stats_layout.rects.light_header_seam.x }}" y="{{ stats_layout.rects.light_header_seam.y }}"
        width="{{ stats_layout.rects.light_header_seam.w }}" height="{{ stats_layout.rects.light_header_seam.h }}"
        fill="var(--dna-seam-color)" opacity="0.6"/>

  {# (7) GitHub glyph + identity + status dot. Glyph at (24,8) 14×14 filled
     with paper-color (--dna-brand-text). Identity user text in paper-color.
     Repo meta in warm-tan muted (label_text). Status dot in gold (seam). #}
  {# Glyph at translate(24, 11) places 14×14 glyph center at (31, 18) which
     aligns with the username text's visual cap-center at y=18.15 (11px font
     at baseline y=22 minus 0.7*11/2). Pre-fix glyph at translate(24, 8)
     centered at y=15, leaving a 3px misalignment above the text. #}
  <g transform="translate({{ stats_layout.rects.brutalist_glyph.x }},{{ stats_layout.rects.brutalist_glyph.y }})">
    <svg viewBox="0 0 24 24" width="{{ stats_layout.rects.brutalist_glyph.w }}" height="{{ stats_layout.rects.brutalist_glyph.h }}">
      <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" fill="var(--dna-glyph-inner, var(--dna-signal))"/>
    </svg>
  </g>
  <text class="{{ uid }}-u" x="{{ stats_layout.texts.identity.x }}" y="{{ stats_layout.texts.identity.y }}"
    {%- if identity_text_length %} textLength="{{ identity_text_length }}" lengthAdjust="spacingAndGlyphs"{%- endif %}>{{ stats_username | upper }}</text>
  {# v0.3.9 algorithmic: identity_x + bio_x come from brutalist paradigm
     stats config; derived identity_zone_width matches the prior magic 70. #}
  <text class="{{ uid }}-m" x="{{ stats_layout.texts.bio.x }}" y="{{ stats_layout.texts.bio.y }}">{{ stats_repo_label }}</text>
  {# Top-right status dot rendered at end of this template (around line 158)
     so it sits ABOVE the dark gradient header panel in z-order. Identical
     (472, 12) 8×8 coordinates as dark partial — single spatial source per
     genome. Old corner ornament at (sw-13, 2) retired for layout parity. #}

  {# (8) STARS label + delta indicator + hero value on PAPER zone.
     STARS (cx-hl) fills with panel-top (--bg). Delta (cx-hm) fills with
     gold. Hero value (cx-hv) fills with dark ink (--ink-primary). y=54
     for label/delta, y=116 for hero (slightly different from dark's y=52,
     y=114). #}
  <text class="{{ uid }}-hl" x="{{ stats_layout.texts.hero_label.x }}" y="{{ stats_layout.texts.hero_label.y }}">STARS</text>
  <text class="{{ uid }}-hm" x="{{ stats_layout.texts.hero_delta.x }}" y="{{ stats_layout.texts.hero_delta.y }}" text-anchor="{{ stats_layout.texts.hero_delta.anchor }}">{{ stars_delta_display | default('LIFETIME') }}</text>
  <text class="{{ uid }}-hv" x="{{ stats_layout.texts.hero_value.x }}" y="{{ stats_layout.texts.hero_value.y }}">{{ stars_display }}</text>

  {# (9) Gold seam rebar at y=128 — stroke-width 2 opacity .5 (lighter
     than dark's 2.5/0.55). #}
  <line x1="{{ stats_layout.lines.hero_rule.x1 }}" y1="{{ stats_layout.lines.hero_rule.y1 }}"
        x2="{{ stats_layout.lines.hero_rule.x2 }}" y2="{{ stats_layout.lines.hero_rule.y2 }}"
        stroke="var(--dna-seam-color)" stroke-width="2" opacity="0.5"/>

  {# (10) Stats grid dividers: vertical gold rule at x=250, horizontal
     ink subrule at y=164. The subrule uses INK (not gold) at 0.15 opacity
     — quiet structural separator between the two stat rows. #}
  <line x1="{{ stats_layout.lines.metric_vertical.x1 }}" y1="{{ stats_layout.lines.metric_vertical.y1 }}"
        x2="{{ stats_layout.lines.metric_vertical.x2 }}" y2="{{ stats_layout.lines.metric_vertical.y2 }}"
        stroke="var(--dna-seam-color)" stroke-width="1" opacity="0.3"/>
  <line x1="{{ stats_layout.lines.metric_row.x1 }}" y1="{{ stats_layout.lines.metric_row.y1 }}"
        x2="{{ stats_layout.lines.metric_row.x2 }}" y2="{{ stats_layout.lines.metric_row.y2 }}"
        stroke="var(--dna-ink-primary)" stroke-width="0.5" opacity="0.15"/>

  {# (11) 4 stat labels + values. cx-sl fills panel-top crimson (--bg),
     cx-sv fills dark ink (--ink-primary). STREAK retained. #}
  {% for slot in metric_layouts %}
  <text class="{{ uid }}-sl" x="{{ slot.label_x }}" y="{{ slot.label_y }}">{{ slot.label_text }}</text>
  <text class="{{ uid }}-sv" x="{{ slot.value_x }}" y="{{ slot.value_y }}" text-anchor="{{ slot.text_anchor }}">{{ slot.value_display }}</text>
  {% endfor %}

  {# (12) Gold seam at y=200 + ACTIVITY/PEAK labels. #}
  <line x1="{{ stats_layout.lines.activity_top.x1 }}" y1="{{ stats_layout.lines.activity_top.y1 }}"
        x2="{{ stats_layout.lines.activity_top.x2 }}" y2="{{ stats_layout.lines.activity_top.y2 }}"
        stroke="var(--dna-seam-color)" stroke-width="2" opacity="0.5"/>
  <text class="{{ uid }}-al" x="{{ stats_layout.texts.activity_label.x }}" y="{{ stats_layout.texts.activity_label.y }}">ACTIVITY · 52W</text>
  <text class="{{ uid }}-al" x="{{ stats_layout.texts.activity_peak.x }}" y="{{ stats_layout.texts.activity_peak.y }}" text-anchor="{{ stats_layout.texts.activity_peak.anchor }}">{% if activity_peak > 0 %}PEAK · {{ activity_peak }}/WK{% else %}PEAK · —{% endif %}</text>

  {# (13) 52 activity bars — fill --dna-signal-dim (the assembler-mapped CSS
     var for the variant's accent_complement stop). Every light variant
     declares accent_complement as the panel-top color (panel_gradient_stops[0]),
     so the histogram reads as the variant's signature dark accent on cream
     paper. Switching from --dna-ink-primary
     (the deep near-black ink) fixes the v0.3.2 regression where bars looked
     like dark-gray smudges instead of ink-stained ledger entries.
     Opacity envelope (.28 → .75 via sqrt scaling) is within the prototype
     range across all six DNAs (.17 → .75). Same width/stride/start_x as dark. #}
  <g fill="var(--dna-signal-dim)" shape-rendering="crispEdges">
  {% for bar in activity_bar_layouts %}
    <rect x="{{ bar.x }}" y="{{ bar.y }}" width="{{ bar.w }}" height="{{ bar.h }}" opacity="{{ bar.opacity }}"/>
  {% endfor %}
  </g>

  {# (14) Language bar zone — y=252→264. Dark gradient PANEL background
     + gold overlay rects + paper-color labels INSIDE the panel. NO seam
     line at y=252 in the light prototype (light replaces that with the
     panel itself). #}
  <rect x="{{ stats_layout.language_shell_rect.x }}" y="{{ stats_layout.language_shell_rect.y }}"
        width="{{ stats_layout.language_shell_rect.w }}" height="{{ stats_layout.language_shell_rect.h }}"
        fill="url(#{{ uid }}-panel)"/>
  {% if language_segments %}
    {% for lang in language_segments %}
      <rect x="{{ lang.x }}" y="{{ lang.y }}" width="{{ lang.w }}" height="{{ lang.h }}" fill="var(--dna-seam-color)" opacity="{{ lang.opacity }}"/>
      {% if lang.show_label %}
      <text x="{{ lang.label_x }}" y="{{ lang.label_y }}" class="{{ uid }}-ll">{{ lang.label_text }}</text>
      {% endif %}
    {% endfor %}
  {% else %}
    <text x="{{ stats_layout.texts.language_empty.x }}" y="{{ stats_layout.texts.language_empty.y }}" class="{{ uid }}-ll">—</text>
  {% endif %}

  {# (15) Gold seam line at y=264 (before footer). #}
  <line x1="{{ stats_layout.lines.language_footer.x1 }}" y1="{{ stats_layout.lines.language_footer.y1 }}"
        x2="{{ stats_layout.lines.language_footer.x2 }}" y2="{{ stats_layout.lines.language_footer.y2 }}"
        stroke="var(--dna-seam-color)" stroke-width="1" opacity="0.4"/>

  {# (16) Footer text (warm-tan muted) + brand (gold). #}
  {# Footer URL x=14 aligns with first language label first letter (also at
     x=14) so the two-row block reads as a single left-edge column. #}
  <text class="{{ uid }}-ft" x="{{ stats_layout.texts.footer_url.x }}" y="{{ stats_layout.texts.footer_url.y }}">github.com/{{ stats_username | lower }}</text>
  <text class="{{ uid }}-fb" x="{{ stats_layout.texts.footer_brand.x }}" y="{{ stats_layout.texts.footer_brand.y }}" text-anchor="{{ stats_layout.texts.footer_brand.anchor }}">HYPERWEAVE</text>

  {# (17) Status dot at (472, 12) 8×8 — unified with dark template (line 64)
     so both substrates have IDENTICAL top-right spatial layout. Pre-fix this
     was a 6×6+2×2 corner ornament at (sw-13, 2) which positioned the element
     differently from the dark partial. Now both substrates render the same
     pulsing status dot at the same coordinates per user's "dark is right,
     apply to light" directive. Animation runs via .{{ uid }}-sd class
     defined in brutalist-defs.j2. #}
  <rect class="{{ uid }}-sd" x="{{ stats_layout.rects.brutalist_status_dot.x }}" y="{{ stats_layout.rects.brutalist_status_dot.y }}"
        width="{{ stats_layout.rects.brutalist_status_dot.w }}" height="{{ stats_layout.rects.brutalist_status_dot.h }}"
        fill="var(--dna-seam-color)"/>
</g>
