{# Chrome badge content: envelope, well, separator, diamond status indicator.
   Specimen: badge-final.svg
   Layer order: envelope -> inner stroke -> well -> chrome bleed -> specular #}
{% set rx = chrome_corner | default('4') %}

{# Chrome envelope #}
<g clip-path="url(#{{ uid }}-clip)">
  <rect width="{{ width }}" height="{{ h }}" fill="url(#{{ uid }}-env)" filter="url(#{{ uid }}-sh)"/>
  <rect x="1" y="1" width="{{ width - 2 }}" height="{{ h - 2 }}" rx="{{ rx | int - 1 }}" fill="none" stroke="#000510" stroke-width="0.6"/>
  <rect class="hw-well" x="2" y="2" width="{{ width - 4 }}" height="{{ h - 4 }}" rx="2" fill="url(#{{ uid }}-well)"/>
  <rect x="2" y="2" width="4" height="{{ h - 4 }}" fill="url(#{{ uid }}-env)" opacity="0.7"/>
</g>

{# Top highlight #}
<rect x="8" y="2" width="{{ width - 16 }}" height="0.5" rx="0.25" fill="{{ specular_light }}" opacity="{{ highlight_opacity | default('0.1') }}"/>

{# Separator line #}
<line x1="{{ lp_w }}" y1="5" x2="{{ lp_w }}" y2="{{ h - 5 }}" stroke="url(#{{ uid }}-sep)" stroke-width="0.75"/>

{# Glyph — glyph_y supplied by compose/layout.py (Invariant 6). #}
{% if has_glyph and glyph_svg %}
<g data-hw-zone="glyph" transform="translate({{ glyph_x }},{{ glyph_y }})">
  {{ glyph_svg | safe }}
</g>
{% endif %}

{# Label — class-styled for chrome paradigm (matches stats/chart typography) #}
{# Chrome uses text-anchor=start with first-character x positions from
   compute_badge_zones. Etched seam (two hairlines: dark cut at seam_left_x,
   specular catch +0.6px right) renders between label and value. #}
{% if seam_left_x and seam_left_x > 0 %}
<line x1="{{ seam_left_x }}" y1="4.5" x2="{{ seam_left_x }}" y2="15.5"
      stroke="var(--dna-seam-gap)" stroke-width="0.6" opacity="0.8"/>
<line x1="{{ seam_specular_x }}" y1="4.5" x2="{{ seam_specular_x }}" y2="15.5"
      stroke="var(--dna-specular, var(--dna-signal))" stroke-width="0.4" opacity="0.09"/>
{% endif %}

<text data-hw-zone="label"
      x="{{ label_x }}" y="{{ text_y }}"
      text-anchor="{{ text_anchor | default('middle') }}" dominant-baseline="central"
      class="{{ uid }}-label"
      fill="var(--dna-signal)"{% if label_text_length and label_text_length > 0 %} textLength="{{ label_text_length }}" lengthAdjust="spacingAndGlyphs"{% endif %}>{{ label_display | default(label) | upper }}</text>

{# Value — Orbitron 10/800. Label and value share y = h/2 + 0.5
   (= 10.5 at h=20), preventing the 1px vertical drift where the label
   sat lower than the value. #}
<text data-hw-zone="value"
      x="{{ value_x }}" y="{{ text_y }}"
      text-anchor="{{ text_anchor | default('middle') }}" dominant-baseline="central"
      class="{{ uid }}-value"
      fill="{{ glyph_fill | default('var(--dna-ink-primary)') }}"{% if value_text_length and value_text_length > 0 %} textLength="{{ value_text_length }}" lengthAdjust="spacingAndGlyphs"{% endif %}>{{ value }}</text>

{# Diamond status indicator — gated on resolver-supplied show_indicator (mode-driven).
   Housing fill + ring stroke route through dedicated --dna-diamond-* vars
   sourced from per-variant diamond_housing / diamond_stroke fields in
   chrome.json. Single-responsibility vars eliminate the --dna-signal-dim
   aliasing that caused warm-tan strokes on horizon (accent_complement was
   warm tan, --dna-signal-dim resolved to it, the var() fallback never fired). #}
{% if show_indicator %}
<g data-hw-zone="status" transform="translate({{ indicator_x + ind_size // 2 }},{{ h // 2 }})">
  <rect x="-4.2" y="-4.2" width="8.4" height="8.4" rx="0.7"
        transform="rotate(45)" fill="var(--dna-diamond-housing, #040C14)"/>
  <rect x="-4.2" y="-4.2" width="8.4" height="8.4" rx="0.7"
        transform="rotate(45)" fill="none" stroke="var(--dna-diamond-stroke, #1A3550)" stroke-width="0.5"/>
  <rect class="hw-logic-bit" x="-2.2" y="-2.2" width="4.4" height="4.4" rx="0.3"
        transform="rotate(45)" fill="var(--dna-status-color, var(--dna-status-passing-core))"/>
</g>
{% endif %}
