{# Chrome status indicator: recessed diamond housing.
   Specimen: badge-diamond-final.svg.
   Housing fill + ring stroke route through dedicated --dna-diamond-* vars
   so chrome variants (graphite/moth/abyssal/lightning) carry their own
   tonal recession sourced from per-variant diamond_housing / diamond_stroke
   fields in chrome.json. Single-responsibility vars eliminate the
   --dna-signal-dim aliasing that bled accent_complement into the stroke. #}
<rect x="{{ strip_zones.status.chrome_outer_x }}" y="{{ strip_zones.status.chrome_outer_y }}"
      width="{{ strip_zones.status.chrome_outer_size }}" height="{{ strip_zones.status.chrome_outer_size }}"
      rx="{{ strip_zones.status.chrome_outer_rx }}"
      transform="rotate(45)" fill="var(--dna-diamond-housing, var(--dna-surface-deep))"/>
<rect x="{{ strip_zones.status.chrome_outer_x }}" y="{{ strip_zones.status.chrome_outer_y }}"
      width="{{ strip_zones.status.chrome_outer_size }}" height="{{ strip_zones.status.chrome_outer_size }}"
      rx="{{ strip_zones.status.chrome_outer_rx }}"
      transform="rotate(45)" fill="none" stroke="var(--dna-diamond-stroke, var(--dna-border))" stroke-width="0.5"/>
<rect class="hw-logic-bit" x="{{ strip_zones.status.chrome_inner_x }}" y="{{ strip_zones.status.chrome_inner_y }}"
      width="{{ strip_zones.status.chrome_inner_size }}" height="{{ strip_zones.status.chrome_inner_size }}"
      rx="{{ strip_zones.status.chrome_inner_rx }}"
      transform="rotate(45)" fill="var(--dna-status-color, var(--dna-status-passing-core))"/>
